# --------------------------------------------------------------------------- #
# LLM provider — one of: ollama (default, fully local), openai, anthropic, stub
# --------------------------------------------------------------------------- #
REGPILOT_LLM=ollama

# --- Ollama (default; required when REGPILOT_LLM=ollama or anthropic) ----- #
# Use http://ollama:11434 inside docker compose, http://localhost:11434 locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=30
REGPILOT_CHAT_MODEL=qwen2.5:3b-instruct
REGPILOT_EMBED_MODEL=nomic-embed-text
REGPILOT_EMBED_PARALLELISM=8

# --- OpenAI (set REGPILOT_LLM=openai to enable) --------------------------- #
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                              # leave blank for the OpenAI default
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic (set REGPILOT_LLM=anthropic to enable) --------------------- #
# Anthropic has no embedding API — embeddings still flow through Ollama, so
# keep OLLAMA_BASE_URL pointing at a reachable Ollama for the dense RAG path.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest

# --------------------------------------------------------------------------- #
# Vector store
# --------------------------------------------------------------------------- #
REGPILOT_CHROMA_DIR=./data/chroma
REGPILOT_DATA_DIR=./data/raw

# --------------------------------------------------------------------------- #
# Pipeline mode
# --------------------------------------------------------------------------- #
# Default (LLM-primary): the LLM drives intake, classification, rerank, and
# synthesizer with structured outputs. Slower (~30-90s e2e on CPU) but
# delivers proper agentic behaviour. Flip any FAST flag to "true" to use the
# deterministic regex/template fast-path for that single node — useful when
# CPU-only Ollama can't hold the SLA.
REGPILOT_INTAKE_FAST=false
REGPILOT_RERANK_FAST=false
REGPILOT_SYNTH_FAST=false

# Semantic-similarity classifier threshold for Annex III area matching.
# Higher = stricter (fewer candidates surfaced to the LLM).
REGPILOT_SEM_THRESHOLD=0.45

# --------------------------------------------------------------------------- #
# LangGraph state durability
# --------------------------------------------------------------------------- #
# "memory" = ephemeral; "sqlite" = file-backed SqliteSaver (docker default).
REGPILOT_CHECKPOINTER=memory
REGPILOT_CHECKPOINT_PATH=./data/checkpoints.sqlite

# --------------------------------------------------------------------------- #
# Logging
# --------------------------------------------------------------------------- #
REGPILOT_LOG_LEVEL=INFO
REGPILOT_LOG_JSON=false
