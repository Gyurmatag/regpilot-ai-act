# LLM backend: "ollama" (default) or "stub" (deterministic fallback for tests/CI)
REGPILOT_LLM=ollama

# Ollama server URL (use http://ollama:11434 inside docker compose)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=30

# Models
REGPILOT_CHAT_MODEL=qwen2.5:3b-instruct
REGPILOT_EMBED_MODEL=nomic-embed-text
REGPILOT_EMBED_PARALLELISM=8

# Vector store
REGPILOT_CHROMA_DIR=./data/chroma

# Raw data
REGPILOT_DATA_DIR=./data/raw

# Fast-path toggles (each short-circuits an expensive LLM call so the default
# install meets a 30s SLA on CPU). Flip to "false" to opt back into the LLM
# path; quality bump is marginal, latency cost is 60-120s per node.
REGPILOT_INTAKE_FAST=true
REGPILOT_RERANK_FAST=true
REGPILOT_SYNTH_FAST=true

# Logging
REGPILOT_LOG_LEVEL=INFO
