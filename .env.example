# LLM backend: "ollama" (default) or "stub" (deterministic fallback for tests/CI)
REGPILOT_LLM=ollama

# Ollama server URL (use http://ollama:11434 inside docker compose)
OLLAMA_BASE_URL=http://localhost:11434

# Models
REGPILOT_CHAT_MODEL=qwen2.5:3b-instruct
REGPILOT_EMBED_MODEL=nomic-embed-text

# Vector store
REGPILOT_CHROMA_DIR=./data/chroma

# Raw data
REGPILOT_DATA_DIR=./data/raw

# Logging
REGPILOT_LOG_LEVEL=INFO
